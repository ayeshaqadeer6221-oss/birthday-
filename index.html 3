<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Birthday Fix</title>

<style>
body{
margin:0;
font-family:Arial;
background:#0b0b1a;
color:white;
}

.page{
display:none;
height:100vh;
padding:20px;
}
.active{display:block;}

.container{
display:flex;
justify-content:space-between;
align-items:center;
height:80vh;
}

.bear{
font-size:120px;
}

.boxes input{
width:40px;
height:40px;
text-align:center;
font-size:20px;
margin:5px;
}

.keypad{
display:grid;
grid-template-columns:repeat(3,60px);
gap:10px;
margin-top:20px;
}

.key{
background:#222;
padding:15px;
text-align:center;
cursor:pointer;
border-radius:10px;
}

button{
margin-top:10px;
padding:10px 20px;
background:#ff4da6;
border:none;
color:white;
border-radius:10px;
cursor:pointer;
}
</style>
</head>

<body>

<!-- PAGE 1 -->
<div class="page active" id="page1">

<h1 style="text-align:center;">Enter Password 🎉</h1>

<div class="container">

<!-- LEFT -->
<div>

<div class="boxes">
<input id="b1" maxlength="1">
<input id="b2" maxlength="1">
<input id="b3" maxlength="1">
<input id="b4" maxlength="1">
<input id="b5" maxlength="1">
<input id="b6" maxlength="1">
</div>

<div class="keypad">
<div class="key" onclick="addNum(1)">1</div>
<div class="key" onclick="addNum(2)">2</div>
<div class="key" onclick="addNum(3)">3</div>
<div class="key" onclick="addNum(4)">4</div>
<div class="key" onclick="addNum(5)">5</div>
<div class="key" onclick="addNum(6)">6</div>
<div class="key" onclick="addNum(7)">7</div>
<div class="key" onclick="addNum(8)">8</div>
<div class="key" onclick="addNum(9)">9</div>
<div class="key" onclick="addNum(0)">0</div>
</div>

<button onclick="check()">Next</button>

</div>

<!-- RIGHT -->
<div class="bear">🐻</div>

</div>
</div>

<!-- PAGE 2 -->
<div class="page" id="page2">
<h1 style="text-align:center;">Cake 🎂</h1>
</div>

<script>

let i = 1;

function addNum(num){
if(i <= 6){
document.getElementById("b"+i).value = num;
i++;
}
}

function check(){

// ✅ FIX: properly get values
let pass =
document.getElementById("b1").value +
document.getElementById("b2").value +
document.getElementById("b3").value +
document.getElementById("b4").value +
document.getElementById("b5").value +
document.getElementById("b6").value;

if(pass === "162024"){
document.getElementById("page1").classList.remove("active");
document.getElementById("page2").classList.add("active");
}
else{
alert("Wrong Password ❌");
}
}

</script>

</body>
</html>
